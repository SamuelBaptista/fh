graph TB
    subgraph Internet
        User([Users / Reviewers])
    end

    subgraph "AWS Account (us-east-1)"
        subgraph "VPC - Default"
            ALB[Application Load Balancer<br/>Port 80 → 8000]

            subgraph "ECS Cluster: watchtower-mini"
                API[API Task<br/>0.25 vCPU / 512 MB<br/>uvicorn app.api.routes:app]
                Worker[Worker Task<br/>0.25 vCPU / 512 MB<br/>python -m app.worker.sqs_poller]
            end
        end

        ECR[ECR Repository<br/>watchtower-mini:latest]
        SQS[[SQS FIFO Queue<br/>watchtower-mini-events.fifo]]

        subgraph "DynamoDB Tables"
            Loads[(watchtower-mini-loads)]
            Events[(watchtower-mini-events)]
            Tools[(watchtower-mini-tool-calls)]
        end

        Secrets[Secrets Manager<br/>API_TOKEN<br/>OPEN_ROUTER_API_KEY]
        Scheduler[EventBridge Scheduler<br/>Timer one-off schedules]
        CW[CloudWatch Logs<br/>/ecs/watchtower-mini]
    end

    subgraph "GitHub"
        Repo[SamuelBaptista/fh]
        Actions[GitHub Actions<br/>CI/CD Pipeline]
    end

    User -->|HTTP| ALB
    ALB --> API
    API --> SQS
    Worker --> SQS
    API --> Loads
    Worker --> Loads
    Worker --> Events
    Worker --> Tools
    Worker --> Scheduler
    Scheduler --> SQS
    API -.->|pull secrets| Secrets
    Worker -.->|pull secrets| Secrets
    API --> CW
    Worker --> CW
    Actions -->|Push image| ECR
    Actions -->|Force deploy| API
    Actions -->|Force deploy| Worker
    ECR -.->|Pull image| API
    ECR -.->|Pull image| Worker
    Repo -->|push to main| Actions

